# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Lance table + transcription pipeline outputs
*.lance/
output/
models/

# Media: don't commit audio/video — examples/ is for JSON only
examples/*.mp3
examples/*.mp4
examples/*.wav
examples/*.ogg
examples/*.m4a
examples/*.flac
examples/*.mov
examples/*.webm


transcripts.lance/
video_batcher.csv
*.log*
input/
thumbnails/
output/
models/
*/node_modules/

# Process logs go to logs/ (see Makefile $(LOG_DIR)). Keep the folder
# tracked via .gitkeep but never commit the rotating log files.
logs/*
!logs/.gitkeep

# SvelteKit build artifacts
frontend/.svelte-kit/
frontend/build/
node_modules/

# Stray local artifacts
images_per.jpg
trocr-test/results/
nohup.out
